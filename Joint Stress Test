def main() -> None:
    validate_input_data()

    results, dc_pareto, dac_pareto = run_stress_test()

    csv_path = (
        OUTPUT_DIR
        / "Fig_S3_cost_stress_results.csv"
    )

    results.to_csv(
        csv_path,
